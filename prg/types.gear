// Variadic args
extern fn printf(s char^, ...);

fn float(d f64, e char^) returns f64 {
    return d + 1.0;
}

// Returning pointers
fn str returns char^ {
    return "Hello, World! %f";
}

fn main {
    // Floats
    let a = 0.1 + 0.2;
    let b = a + 4.0;

    // Pointers
    let deref = 5;
    let ptr = #deref;

    // Strings
    let c = "Hello, World!";

    // Checking the deref
    printf("%d\n", @ptr);

    return 0;
}
